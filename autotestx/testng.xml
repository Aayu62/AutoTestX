<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="AutoTestX — Full Suite"
       parallel="tests"
       thread-count="4"
       verbose="1"
       data-provider-thread-count="2">

    <listeners>
        <listener class-name="com.autotestx.listeners.TestListener"/>
    </listeners>

    <!-- ── Authentication Tests ─────────────────────────────────────── -->
    <test name="Auth — Register" preserve-order="true">
        <classes>
            <class name="com.autotestx.tests.auth.RegisterTests"/>
        </classes>
    </test>

    <test name="Auth — Login" preserve-order="true">
        <classes>
            <class name="com.autotestx.tests.auth.LoginTests"/>
        </classes>
    </test>

    <test name="Auth — Tokens" preserve-order="true">
        <classes>
            <class name="com.autotestx.tests.auth.TokenTests"/>
        </classes>
    </test>

    <!-- ── Book Tests ────────────────────────────────────────────────── -->
    <test name="Books — CRUD" preserve-order="true">
        <classes>
            <class name="com.autotestx.tests.books.BookCrudTests"/>
        </classes>
    </test>

    <test name="Books — Search &amp; Pagination" preserve-order="true">
        <classes>
            <class name="com.autotestx.tests.books.BookSearchTests"/>
        </classes>
    </test>

    <!-- ── Order Tests ───────────────────────────────────────────────── -->
    <test name="Orders" preserve-order="true">
        <classes>
            <class name="com.autotestx.tests.orders.OrderTests"/>
        </classes>
    </test>

    <!-- ── Review Tests ──────────────────────────────────────────────── -->
    <test name="Reviews" preserve-order="true">
        <classes>
            <class name="com.autotestx.tests.reviews.ReviewTests"/>
        </classes>
    </test>

    <!-- ── User Tests ────────────────────────────────────────────────── -->
    <test name="Users" preserve-order="true">
        <classes>
            <class name="com.autotestx.tests.users.UserTests"/>
        </classes>
    </test>

    <!-- ── Security Tests ───────────────────────────────────────────── -->
    <test name="Security" preserve-order="true">
        <classes>
            <class name="com.autotestx.tests.security.SecurityTests"/>
        </classes>
    </test>

    <!-- ── Database Validation Tests ───────────────────────────────── -->
    <test name="Database Validation" preserve-order="true">
        <classes>
            <class name="com.autotestx.tests.database.DBValidationTests"/>
        </classes>
    </test>

</suite>
