<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="30">
    <Properties>
        <Property name="LOG_DIR">logs</Property>
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level [%logger{36}] - %msg%n</Property>
    </Properties>

    <Appenders>
        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout>
                <Pattern>%d{HH:mm:ss} [%t] %-5level %logger{20} - %msg%n</Pattern>
            </PatternLayout>
        </Console>

        <!-- Rolling File Appender - All logs -->
        <RollingFile name="RollingFile"
                     fileName="${LOG_DIR}/autotestx.log"
                     filePattern="${LOG_DIR}/autotestx-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout>
                <Pattern>${LOG_PATTERN}</Pattern>
            </PatternLayout>
            <Policies>
                <TimeBasedTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>

        <!-- API Requests/Responses log -->
        <RollingFile name="APILog"
                     fileName="${LOG_DIR}/api-requests.log"
                     filePattern="${LOG_DIR}/api-requests-%d{yyyy-MM-dd}.log">
            <PatternLayout>
                <Pattern>%d{yyyy-MM-dd HH:mm:ss} %msg%n</Pattern>
            </PatternLayout>
            <Policies>
                <TimeBasedTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="20MB"/>
            </Policies>
        </RollingFile>

        <!-- Test Results log -->
        <File name="TestResults"
              fileName="${LOG_DIR}/test-results.log"
              append="true">
            <PatternLayout>
                <Pattern>${LOG_PATTERN}</Pattern>
            </PatternLayout>
        </File>
    </Appenders>

    <Loggers>
        <!-- Framework loggers -->
        <Logger name="com.autotestx" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Logger>

        <!-- REST Assured logging -->
        <Logger name="io.restassured" level="WARN" additivity="false">
            <AppenderRef ref="APILog"/>
        </Logger>

        <!-- Apache HTTP Client -->
        <Logger name="org.apache.http" level="WARN" additivity="false">
            <AppenderRef ref="RollingFile"/>
        </Logger>

        <!-- Root logger -->
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Root>
    </Loggers>
</Configuration>
